# OmniExporter AI Git Ignore

# Config with secrets - never commit!
config.js

# Node modules (for Cloudflare Worker)
node_modules/

# Build artifacts
dist/
*.zip

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Temporary files
repos.txt

# Debug/HAR response dumps — never commit user data
*_response.json
*_pretty.json
*_debug.json

perplexityhar.txt


# Development/test scripts — not part of the extension
analyze_*.js
browser-e2e-tests.js
tests.js
*_tests.js
*_test.js

# Internal dev notes (keep in branches, not master)
*_ANALYSIS.md
*_FINDINGS.md
*_SUMMARY.md
*_AUDIT.md
