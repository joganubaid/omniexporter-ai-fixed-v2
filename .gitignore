# OmniExporter AI Git Ignore

# Config with secrets - never commit!
config.js

# Node modules (for Cloudflare Worker)
node_modules/

# Build artifacts
dist/
*.zip

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Temporary files
repos.txt

# Debug/HAR response dumps — never commit user data
*_response.json
*_pretty.json
*_debug.json
*.har

# Sensitive API data
claude_*.json
chatgpt_*.json
perplexity_*.json
gemini_*.json
grok_*.json
deepseek_*.json
