# OmniExporter AI Git Ignore

# Config with secrets - never commit!
# NOTE: config.js itself IS committed with safe placeholder defaults so that the
# <script src="../../config.js"> tags in popup.html and options.html always resolve,
# and importScripts('../config.js') in background.js does not silently fail.
# Developers replace the placeholder values with their own credentials locally.
# If you have created a personal config.js with real credentials, add a local
# .git/info/exclude entry or use `git update-index --assume-unchanged config.js`.

# Node modules (for Cloudflare Worker)
node_modules/

# Build artifacts
dist/
*.zip

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Temporary files
repos.txt

# Debug/HAR response dumps — never commit user data
*_response.json
*_pretty.json
*_debug.json

# HAR files — contain sensitive user session data and are very large
*.har

perplexityhar.txt


# Development/test scripts — not part of the extension
analyze_*.js
browser-e2e-tests.js
tests.js
*_tests.js
*_test.js

# Internal dev notes (keep in branches, not master)
*_ANALYSIS.md
*_FINDINGS.md
*_SUMMARY.md
*_AUDIT.md
API_ENDPOINTS_ANALYSIS.md
API_ANALYSIS_*.md
API_ENDPOINTS_*.txt
api_endpoints_*.json
